# Base de données G5API (MySQL)
MYSQL_HOST=192.168.1.x
MYSQL_PORT=3306
MYSQL_DATABASE=get5
MYSQL_USER=get5
MYSQL_PASSWORD=

# Optionnel : filtrer par saison G5API
SEASON_ID=

# URL de base du serveur G5API (pour les démos) — ex. http://192.168.1.10:3301
# Si défini, les démos sont servies via GET {G5API_URL}/api/demo/{filename}
# Si vide, fallback sur les fichiers locaux dans data/demo/
G5API_URL=

# Steam API (avatars)
STEAM_API_KEY=

# Mots de passe panel admin
ADMIN_PASSWORD=
BRACKETS_ADMIN_PASSWORD=
